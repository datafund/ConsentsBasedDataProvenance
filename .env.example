# Testnet deployer wallet private key (without 0x prefix)
# WARNING: For testnets only. Use hardware wallet or multisig for mainnet deployments.
TESTNET_DEPLOYER_PRIVATE_KEY=

# RPC URLs (defaults shown; replace with Alchemy/Infura for reliability)
SEPOLIA_RPC_URL=https://rpc.sepolia.org
CHIADO_RPC_URL=https://rpc.chiadochain.net
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Block explorer API keys (for contract verification)
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=

# Optional
REPORT_GAS=false
